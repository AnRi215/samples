# === Allgemein ===
VW_LOG_FILE=/data/vaultwarden.log

# === Netzwerk ===
VW_HOST_PORT=XXXXXXXXXXXXXXXXXX
VW_DOMAIN=https://XXXXXXXXXXXXXXXXXX.de
# === DB ===

VW_DB_HOST=XXXXXXXXXXXXXXXXXX
VW_DB_NAME=XXXXXXXXXXXXXXXXXX
VW_DB_USER=XXXXXXXXXXXXXXXXXX
VW_DB_PASS=XXXXXXXXXXXXXXXXXX

# === SMTP ===
VW_SMTP_HOST=XXXXXXXXXXXXXXXXXX
VW_SMTP_FROM=no-reply@XXXXXXXXXXXXXXXXXX.de
VW_SMTP_FROM_NAME=Vaultwarden
VW_SMTP_SECURITY=XXXXXXXXXXXXXXXXXX
VW_SMTP_PORT=465
VW_SMTP_USERNAME=XXXXXXXXXXXXXXXXXX
VW_SMTP_PASSWORD=XXXXXXXXXXXXXXXXXX
VW_SMTP_TIMEOUT=30
VW_SMTP_AUTH_MECHANISM=XXXXXXXXXXXXXXXXXX

# === Flags / Limits/ Security ===
VW_WS_ENABLED=true
VW_SIGNUPS_ALLOWED=false
VW_INVITATIONS_ALLOWED=true
VW_INVITATION_ORG_NAME=XXXXXXXXXXXXXXXXXX
VW_LOGIN_RATELIMIT_MAX_BURST=10
VW_LOGIN_RATELIMIT_SECONDS=60
VW_ADMIN_RATELIMIT_SECONDS=300
VW_ADMIN_RATELIMIT_MAX_BURST=5
VW_USE_REAL_IP=true
VW_IP_HEADER=X-Forwarded-For
VW_EXPERIMENTAL_FLAGS=extension-refresh,ssh-key-vault-item,ssh-agent-v2

# === Admin Token ===
VW_ADMIN_TOKEN=XXXXXXXXXXXXXXXXXX